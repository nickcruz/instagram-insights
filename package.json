{
  "name": "instasights",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace @instasights/web dev",
    "build": "yarn workspace @instasights/cli build && yarn workspace @instasights/web build",
    "build:cli": "yarn workspace @instasights/cli build",
    "lint": "yarn workspace @instasights/web lint",
    "typecheck": "yarn workspace @instasights/cli typecheck && yarn workspace @instasights/web typecheck",
    "test": "yarn test:cli && yarn test:web && yarn test:transcriber",
    "test:cli": "yarn workspace @instasights/cli test",
    "test:web": "yarn workspace @instasights/web test",
    "test:transcriber": "python3 -m pytest services/transcriber/tests",
    "infra:synth": "yarn workspace @instasights/infra synth",
    "db:generate": "yarn workspace @instasights/db db:generate",
    "db:push": "yarn workspace @instasights/db db:push"
  },
  "devDependencies": {
    "esbuild": "^0.25.11",
    "tsx": "^4.21.0"
  }
}
